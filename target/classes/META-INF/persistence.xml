<?xml version="1.0" encoding="UTF-8"?>

<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             version="2.2">

    <persistence-unit name="jpa-unit">

        <provider>
            org.hibernate.jpa.HibernatePersistenceProvider
        </provider>
      <class>com.example.Customer</class>
      <class>com.example.Course</class>
      <class>com.example.Product</class>
      <class>com.example.Employee</class>
      <class>com.example.LibMembership</class>
      <class>com.example.Title</class>
      <class>com.example.Publisher</class>
      <class>com.example.Sale</class>
      <class>com.example.Prod</class>
      <class>com.example.Title1</class>
      <class>com.example.Transaction_prod</class>
      <class>com.example.Courses</class>
      <class>com.example.OfflineCourse</class>
      <class>com.example.OnlineCourse</class>
      <class>com.example.Order</class>
      <class>com.example.OrdProduct</class>
      <class>com.example.OrderProduct</class>
        <properties>

            <property
                name="javax.persistence.jdbc.driver"
                value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>

            <property
                name="javax.persistence.jdbc.url"
                value="jdbc:sqlserver://localhost:1433;databaseName=mysql;encrypt=true;trustServerCertificate=true"/>

            <property
                name="javax.persistence.jdbc.user"
                value="sa"/>

            <property
                name="javax.persistence.jdbc.password"
                value="Admin@1234"/>

            <property
                name="hibernate.dialect"
                value="org.hibernate.dialect.SQLServer2012Dialect"/>

            <property
                name="hibernate.show_sql"
                value="true"/>

            <property
                name="hibernate.format_sql"
                value="true"/>

            <property
                name="hibernate.hbm2ddl.auto"
                value="update"/>

        </properties>

    </persistence-unit>

</persistence>